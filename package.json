{
  "name": "agent-sdd-toolkit",
  "version": "1.0.2",
  "description": "Plug and play CLI to prepare machines and repositories for agent-agnostic Spec Driven Development with Spec Kit, AGENTS.md, AI agent adapters and executable harness validation.",
  "type": "module",
  "bin": {
    "agent-sdd": "./bin/agent-sdd.js"
  },
  "files": [
    "bin/",
    "src/",
    "templates/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node ./bin/agent-sdd.js",
    "doctor": "node ./bin/agent-sdd.js doctor --agents all --no-run-init",
    "test": "node --test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepack": "npm test && npm run lint && npm run format:check"
  },
  "keywords": [
    "agents",
    "ai-agents",
    "spec-kit",
    "sdd",
    "codex",
    "claude-code",
    "copilot",
    "cursor",
    "harness"
  ],
  "author": "mikiguillamon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikiguillamon/agent-sdd-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/mikiguillamon/agent-sdd-toolkit/issues"
  },
  "homepage": "https://github.com/mikiguillamon/agent-sdd-toolkit#readme",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "eslint": "^9.29.0",
    "prettier": "^3.5.3"
  }
}
